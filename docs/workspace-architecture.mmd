flowchart TB
    subgraph ws["my-project/ — Winter Workspace"]
        direction TB

        subgraph root["workspace root ./ — winter.git workspace branch"]
            direction LR
            agents["<b>.claude/agents/</b><br/>agentic-development-manager<br/>product-engineer, product-specialist"]
            skills["<b>.claude/skills/</b><br/>commit, todo, ws, ws-setup,<br/>ws-status, ws-sync, ws-work"]
            ai_project["<b>ai/project/</b><br/>branches.md<br/>contributing.md<br/>project-setup.md<br/>workflow.sh"]
            ai_setup["<b>ai/setup/</b><br/>Guides for creating<br/>integration config"]
            workflow["<b>workflow/</b><br/>up, down, status"]
        end

        subgraph product_wt["product/ — winter.git product branch worktree"]
            direction LR
            product_content["<b>plans/ & todos/</b><br/>product backlog"]
        end

        subgraph projects_dir["projects/ — source checkouts (never edit directly)"]
            direction LR
            repo1["<b>&lt;repo-1&gt;/</b><br/>Project repo<br/>main branch"]
            repo2["<b>&lt;repo-2&gt;/</b><br/>Project repo<br/>main branch"]
            repoN["<b>&lt;repo-n&gt;/</b><br/>Project repo<br/>main branch"]
        end

        subgraph alpha_wt["alpha/ — feature worktree (port offset +1)"]
            direction LR
            alpha_repo1["<b>&lt;repo-1&gt;/</b><br/>alpha branch"]
            alpha_repo2["<b>&lt;repo-2&gt;/</b><br/>alpha branch"]
            alpha_repoN["<b>&lt;repo-n&gt;/</b><br/>alpha branch"]
            alpha_scripts["<b>up</b> → workflow/up<br/><b>down</b> → workflow/down<br/><b>status</b> → workflow/status"]
        end

        subgraph beta_wt["beta/ — feature worktree (port offset +2)"]
            direction LR
            beta_repo1["<b>&lt;repo-1&gt;/</b><br/>beta branch"]
            beta_repo2["<b>&lt;repo-2&gt;/</b><br/>beta branch"]
            beta_repoN["<b>&lt;repo-n&gt;/</b><br/>beta branch"]
            beta_scripts["<b>up</b> → workflow/up<br/><b>down</b> → workflow/down<br/><b>status</b> → workflow/status"]
        end
    end

    root ~~~ product_wt
    root ~~~ projects_dir
    product_wt ~~~ alpha_wt
    projects_dir ~~~ beta_wt

    classDef winterNode fill:#533483,stroke:#e94560,color:#fff
    classDef projectNode fill:#1a6fb5,stroke:#53a8e2,color:#fff
    classDef integrationNode fill:#2d6a4f,stroke:#52b788,color:#fff
    classDef winterContainer fill:#1c1040,stroke:#e94560,color:#eee
    classDef projectContainer fill:#0a2744,stroke:#53a8e2,color:#eee
    classDef integrationContainer fill:#1b3a2d,stroke:#52b788,color:#eee

    class root winterContainer
    class product_wt winterContainer
    class projects_dir projectContainer
    class alpha_wt,beta_wt integrationContainer
    class agents,skills,workflow,ai_setup winterNode
    class ai_project integrationNode
    class product_content winterNode
    class repo1,repo2,repoN projectNode
    class alpha_repo1,alpha_repo2,alpha_repoN,alpha_scripts integrationNode
    class beta_repo1,beta_repo2,beta_repoN,beta_scripts integrationNode

    style ws fill:#0d1117,stroke:#30363d,color:#c9d1d9
